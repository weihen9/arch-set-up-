* { background: #2e3440; foreground: #eceff4; surface: #3b4252; accent: #88c0d0; font: "JetBrainsMono Nerd Font 12"; }
window { width: 42%; border-radius: 18px; background-color: @background; border: 2px; border-color: @accent; }
mainbox { padding: 18px; }
inputbar { padding: 12px; border-radius: 12px; background-color: @surface; text-color: @foreground; }
listview { margin: 12px 0 0 0; lines: 8; columns: 1; fixed-height: false; }
element { padding: 10px; border-radius: 12px; text-color: @foreground; }
element selected { background-color: @accent; text-color: @background; }
